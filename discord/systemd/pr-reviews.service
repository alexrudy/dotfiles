[Unit]
Description=PR review sweep (alexrudy)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/dev/discord/discord
EnvironmentFile=-%h/dev/discord/discord/.env
Environment=PATH=%h/.local/bin:%h/.cargo/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=uv run misc/users/alexrudy/exp-pr-reviews/pr_reviews.py sweep --apply
