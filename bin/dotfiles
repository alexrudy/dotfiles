#!/usr/bin/env python3

import argparse
import glob
import subprocess


def main():
    parser = argparse.ArgumentParser()
    subcommands = parser.add_subparsers(title="commands", required=True)
    parse_install = subcommands.add_parser("install", help="run an included install script")
    parse_install.add_argument("name", help="install script target")
    parse_install.set_defaults(func=install)
    args = parser.parse_args()
    args.func(args)


def install(args: argparse.Namespace) -> None:
    target = args.name

    for installer in glob.iglob(f"*/install-{target}.sh"):
        print(f"Installing {target} from {installer}")
        subprocess.run(["bash", installer], check=True)
    print(f"Finished installing {target}")


if __name__ == "__main__":
    main()
